msgid "You left something behind!"
msgstr "Hai dimenticato qualcosa!"

msgid "Your cart is waiting – items may sell out!"
msgstr "Il tuo carrello ti aspetta – i prodotti potrebbero esaurirsi!"

msgid "Here's a special offer to complete your purchase!"
msgstr "Ecco un'offerta speciale per completare il tuo acquisto!"

msgid "Complete Your Purchase"
msgstr "Completa il tuo acquisto"

msgid "Unsubscribe"
msgstr "Annulla iscrizione"

msgid "Wait! Don't leave your cart behind."
msgstr "Aspetta! Non abbandonare il tuo carrello."

msgid "Save My Cart"
msgstr "Salva il mio carrello"

msgid "Enter your email and we'll save your cart so you can complete your purchase later."
msgstr "Inserisci la tua e-mail e salveremo il tuo carrello per completare l'acquisto in seguito."

msgid "No thanks, I don't want to save my cart."
msgstr "No grazie, non voglio salvare il mio carrello."

msgid "Your cart has been restored! Complete your purchase below."
msgstr "Il tuo carrello è stato ripristinato! Completa il tuo acquisto qui sotto."

msgid "You have been successfully unsubscribed from cart reminder emails."
msgstr "Sei stato cancellato con successo dalle e-mail di promemoria del carrello."

msgid "Discount code expires in 72 hours."
msgstr "Il codice sconto scade tra 72 ore."

msgid "Claim My Discount"
msgstr "Richiedi il mio sconto"

msgid "Last chance to complete your purchase!"
msgstr "Ultima occasione per completare il tuo acquisto!"

msgid "Restoring your cart…"
msgstr "Ripristino del carrello…"

msgid "Continue to Checkout"
msgstr "Procedi al pagamento"

msgid "Abandoned Carts"
msgstr "Carrelli Abbandonati"

msgid "Dashboard"
msgstr "Pannello di controllo"

msgid "Settings"
msgstr "Impostazioni"

msgid "Upgrade to Pro"
msgstr "Passa a Pro"

msgid "Recovery Rate"
msgstr "Tasso di recupero"

msgid "Revenue Recovered"
msgstr "Entrate recuperate"

msgid "Revenue Lost"
msgstr "Entrate perse"
