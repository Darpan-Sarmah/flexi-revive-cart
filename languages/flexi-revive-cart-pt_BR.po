msgid "You left something behind!"
msgstr "Você esqueceu algo!"

msgid "Your cart is waiting – items may sell out!"
msgstr "Seu carrinho está esperando – os itens podem esgotar!"

msgid "Here's a special offer to complete your purchase!"
msgstr "Aqui está uma oferta especial para concluir sua compra!"

msgid "Complete Your Purchase"
msgstr "Conclua sua compra"

msgid "Unsubscribe"
msgstr "Cancelar inscrição"

msgid "Wait! Don't leave your cart behind."
msgstr "Espere! Não abandone seu carrinho."

msgid "Save My Cart"
msgstr "Salvar meu carrinho"

msgid "Enter your email and we'll save your cart so you can complete your purchase later."
msgstr "Insira seu e-mail e salvaremos seu carrinho para que você possa concluir sua compra depois."

msgid "No thanks, I don't want to save my cart."
msgstr "Não, obrigado, não quero salvar meu carrinho."

msgid "Your cart has been restored! Complete your purchase below."
msgstr "Seu carrinho foi restaurado! Conclua sua compra abaixo."

msgid "You have been successfully unsubscribed from cart reminder emails."
msgstr "Você cancelou com sucesso a inscrição nos e-mails de lembrete do carrinho."

msgid "Discount code expires in 72 hours."
msgstr "O código de desconto expira em 72 horas."

msgid "Claim My Discount"
msgstr "Resgatar meu desconto"

msgid "Last chance to complete your purchase!"
msgstr "Última chance para concluir sua compra!"

msgid "Restoring your cart…"
msgstr "Restaurando seu carrinho…"

msgid "Continue to Checkout"
msgstr "Continuar para o pagamento"

msgid "Abandoned Carts"
msgstr "Carrinhos Abandonados"

msgid "Dashboard"
msgstr "Painel"

msgid "Settings"
msgstr "Configurações"

msgid "Upgrade to Pro"
msgstr "Atualizar para Pro"

msgid "Recovery Rate"
msgstr "Taxa de recuperação"

msgid "Revenue Recovered"
msgstr "Receita recuperada"

msgid "Revenue Lost"
msgstr "Receita perdida"
