msgid "You left something behind!"
msgstr "لقد تركت شيئًا خلفك!"

msgid "Your cart is waiting – items may sell out!"
msgstr "سلة التسوق الخاصة بك في انتظارك – قد تنفد المنتجات!"

msgid "Here's a special offer to complete your purchase!"
msgstr "إليك عرض خاص لإتمام عملية الشراء!"

msgid "Complete Your Purchase"
msgstr "أكمل عملية الشراء"

msgid "Unsubscribe"
msgstr "إلغاء الاشتراك"

msgid "Wait! Don't leave your cart behind."
msgstr "انتظر! لا تترك سلة التسوق الخاصة بك."

msgid "Save My Cart"
msgstr "احفظ سلة التسوق"

msgid "Enter your email and we'll save your cart so you can complete your purchase later."
msgstr "أدخل بريدك الإلكتروني وسنحفظ سلة التسوق الخاصة بك حتى تتمكن من إتمام الشراء لاحقًا."

msgid "No thanks, I don't want to save my cart."
msgstr "لا شكرًا، لا أريد حفظ سلة التسوق الخاصة بي."

msgid "Your cart has been restored! Complete your purchase below."
msgstr "تمت استعادة سلة التسوق الخاصة بك! أكمل عملية الشراء أدناه."

msgid "You have been successfully unsubscribed from cart reminder emails."
msgstr "تم إلغاء اشتراكك بنجاح من رسائل تذكير سلة التسوق."

msgid "Discount code expires in 72 hours."
msgstr "ينتهي رمز الخصم خلال 72 ساعة."

msgid "Claim My Discount"
msgstr "احصل على الخصم"

msgid "Last chance to complete your purchase!"
msgstr "الفرصة الأخيرة لإتمام عملية الشراء!"

msgid "Restoring your cart…"
msgstr "جارٍ استعادة سلة التسوق…"

msgid "Continue to Checkout"
msgstr "المتابعة إلى الدفع"

msgid "Abandoned Carts"
msgstr "سلات التسوق المتروكة"

msgid "Dashboard"
msgstr "لوحة التحكم"

msgid "Settings"
msgstr "الإعدادات"

msgid "Upgrade to Pro"
msgstr "الترقية إلى النسخة الاحترافية"

msgid "Recovery Rate"
msgstr "معدل الاسترداد"

msgid "Revenue Recovered"
msgstr "الإيرادات المستردة"

msgid "Revenue Lost"
msgstr "الإيرادات المفقودة"
