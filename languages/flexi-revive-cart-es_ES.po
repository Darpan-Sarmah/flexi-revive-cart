msgid "You left something behind!"
msgstr "¡Dejaste algo atrás!"

msgid "Your cart is waiting – items may sell out!"
msgstr "¡Tu carrito te espera – los artículos pueden agotarse!"

msgid "Here's a special offer to complete your purchase!"
msgstr "¡Aquí tienes una oferta especial para completar tu compra!"

msgid "Complete Your Purchase"
msgstr "Completar mi compra"

msgid "Unsubscribe"
msgstr "Cancelar suscripción"

msgid "Wait! Don't leave your cart behind."
msgstr "¡Espera! No abandones tu carrito."

msgid "Save My Cart"
msgstr "Guardar mi carrito"

msgid "Enter your email and we'll save your cart so you can complete your purchase later."
msgstr "Ingresa tu correo y guardaremos tu carrito para que puedas completar tu compra más tarde."

msgid "No thanks, I don't want to save my cart."
msgstr "No gracias, no quiero guardar mi carrito."

msgid "Your cart has been restored! Complete your purchase below."
msgstr "¡Tu carrito ha sido restaurado! Completa tu compra a continuación."

msgid "You have been successfully unsubscribed from cart reminder emails."
msgstr "Te has dado de baja correctamente de los correos de recordatorio de carrito."

msgid "Discount code expires in 72 hours."
msgstr "El código de descuento expira en 72 horas."

msgid "Claim My Discount"
msgstr "Reclamar mi descuento"

msgid "Last chance to complete your purchase!"
msgstr "¡Última oportunidad para completar tu compra!"

msgid "Restoring your cart…"
msgstr "Restaurando tu carrito…"

msgid "Continue to Checkout"
msgstr "Continuar al pago"

msgid "Abandoned Carts"
msgstr "Carritos Abandonados"

msgid "Dashboard"
msgstr "Panel de Control"

msgid "Settings"
msgstr "Configuración"

msgid "Upgrade to Pro"
msgstr "Actualizar a Pro"

msgid "Recovery Rate"
msgstr "Tasa de Recuperación"

msgid "Revenue Recovered"
msgstr "Ingresos Recuperados"

msgid "Revenue Lost"
msgstr "Ingresos Perdidos"
